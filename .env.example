DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id

# Optional but recommended during setup so slash commands update instantly.
# Use your Discord server ID.
GUILD_ID=your_guild_id_here

# Optional: override the default backup channel (1517946266800095232).
BACKUP_CHANNEL_ID=1517946266800095232

# Render sets PORT automatically. Keep this only for local testing.
PORT=3000
